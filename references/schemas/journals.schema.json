{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-for-accounting.local/schemas/journals.schema.json",
  "title": "JournalBatch",
  "type": "object",
  "required": [
    "schema_version",
    "client_slug",
    "currency",
    "journals"
  ],
  "properties": {
    "schema_version": {
      "const": "0.0.1"
    },
    "client_slug": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "journals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "je_number",
          "date",
          "narration",
          "lines"
        ],
        "properties": {
          "je_number": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "narration": {
            "type": "string"
          },
          "source_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "lines": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "account_code",
                "account_name",
                "debit",
                "credit"
              ],
              "properties": {
                "account_code": {
                  "type": "string"
                },
                "account_name": {
                  "type": "string"
                },
                "debit": {
                  "type": "number",
                  "minimum": 0
                },
                "credit": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
