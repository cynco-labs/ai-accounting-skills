{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-for-accounting.local/schemas/transactions.schema.json",
  "title": "TransactionRegister",
  "type": "object",
  "required": [
    "schema_version",
    "client_slug",
    "currency",
    "transactions"
  ],
  "properties": {
    "schema_version": {
      "const": "0.0.1"
    },
    "client_slug": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "bank_accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "account_number_last4": {
            "type": "string"
          },
          "opening_balance": {
            "type": "number"
          },
          "closing_balance": {
            "type": "number"
          },
          "statement_period_start": {
            "type": "string"
          },
          "statement_period_end": {
            "type": "string"
          }
        }
      }
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "date",
          "description",
          "amount",
          "direction",
          "source_file"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "direction": {
            "enum": [
              "inflow",
              "outflow"
            ]
          },
          "bank_account_id": {
            "type": "string"
          },
          "running_balance": {
            "type": [
              "number",
              "null"
            ]
          },
          "account_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "account_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "classification_basis": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "enum": [
                  "prior_year",
                  "pattern",
                  "invoice",
                  "employee",
                  "suspense",
                  "opening"
                ]
              }
            ]
          },
          "counterparty": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_file": {
            "type": "string"
          },
          "source_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "tax_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": true
}
