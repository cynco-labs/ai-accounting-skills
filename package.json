{
  "name": "@cynco/accounting-skills",
  "version": "2.3.1",
  "description": "Accounting CLI for coding agents \u2014 extract banks, classify, post, trial balance, close, Beancount + Fava. Install skills via skills.sh. npx @cynco/accounting-skills demo",
  "keywords": [
    "accounting",
    "beancount",
    "fava",
    "claude-code",
    "agent-skills",
    "skills.sh",
    "bookkeeping",
    "mpers",
    "maybank"
  ],
  "homepage": "https://github.com/cynco-labs/ai-accounting-skills",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cynco-labs/ai-accounting-skills.git"
  },
  "bugs": {
    "url": "https://github.com/cynco-labs/ai-accounting-skills/issues"
  },
  "license": "MIT",
  "author": "Hazli Johar <coding@hazli.dev>",
  "type": "module",
  "bin": {
    "accounting-skills": "cli/bin/ai-accounting.js",
    "ai-accounting": "cli/bin/ai-accounting.js",
    "cynco-accounting": "cli/bin/ai-accounting.js"
  },
  "files": [
    "cli/**/*",
    "scripts/**/*.py",
    "scripts/**/*.sh",
    "fixtures/golden-mini-sdn-bhd/**/*",
    "fixtures/golden-books-only-mini/**/*",
    "fixtures/bank/**/*",
    "references/coa_templates/**/*",
    "references/schemas/**/*",
    "references/classification_patterns.json",
    "references/depth_gates.json",
    "requirements.txt",
    "README.md",
    "LICENSE",
    "NOTICE",
    "VERSION"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "ai-accounting": "node ./cli/bin/ai-accounting.js",
    "demo": "node ./cli/bin/ai-accounting.js demo",
    "close": "node ./cli/bin/ai-accounting.js close",
    "check": "node ./cli/bin/ai-accounting.js check",
    "test": "python3 -m unittest discover -s tests -v",
    "pub": "npm publish --access public"
  },
  "publishConfig": {
    "access": "public"
  }
}
