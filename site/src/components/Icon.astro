---
/** Minimal line icons — stats density, no decoration */
interface Props {
  name: "folder" | "scale" | "file" | "ledger" | "arrow" | "check"
  size?: number
}
const { name, size = 20 } = Astro.props
---

<svg
  data-slot="icon"
  width={size}
  height={size}
  viewBox="0 0 20 20"
  fill="none"
  aria-hidden="true"
>
  {
    name === "folder" && (
      <path
        d="M2.5 5.5h5l1.5 1.5H17.5v8.5H2.5V5.5Z"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "scale" && (
      <>
        <path d="M10 3v14" stroke="currentColor" stroke-width="1.3" />
        <path d="M4 7h12" stroke="currentColor" stroke-width="1.3" />
        <path d="M4 7l-1.5 5h3L4 7Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
        <path d="M16 7l-1.5 5h3L16 7Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
      </>
    )
  }
  {
    name === "file" && (
      <path
        d="M6 3.5h5.5L15.5 7.5V16.5H6V3.5Z"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "ledger" && (
      <>
        <rect x="3.5" y="3.5" width="13" height="13" stroke="currentColor" stroke-width="1.3" />
        <path d="M7 3.5v13M3.5 7.5h13M3.5 11.5h13" stroke="currentColor" stroke-width="1.3" />
      </>
    )
  }
  {
    name === "arrow" && (
      <path d="M4 10h11M11.5 5.5 16 10l-4.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="square" />
    )
  }
  {
    name === "check" && (
      <path d="M4 10.5 8 14.5 16 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square" />
    )
  }
</svg>
