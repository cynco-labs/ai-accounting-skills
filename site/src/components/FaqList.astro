---
import { faqs } from "../data/site"
---

<section id="faq" data-section="faq">
  <p data-slot="section-title">
    <strong>Common questions.</strong>
    <span>Straight answers.</span>
  </p>
  <div data-component="faq">
    {
      faqs.map((item) => (
        <div data-faq-item>
          <button type="button" data-slot="faq-question" aria-expanded="false">
            <svg
              data-slot="faq-icon"
              class="icon-plus"
              viewBox="0 0 16 16"
              fill="currentColor"
              width="16"
              height="16"
              aria-hidden="true"
            >
              <path d="M7.5 7.5V3H8.5V7.5H13V8.5H8.5V13H7.5V8.5H3V7.5H7.5Z" />
            </svg>
            <svg
              data-slot="faq-icon"
              class="icon-minus"
              viewBox="0 0 16 16"
              fill="currentColor"
              width="16"
              height="16"
              aria-hidden="true"
              style="display: none"
            >
              <path d="M3 7.5H13V8.5H3V7.5Z" />
            </svg>
            <span data-slot="faq-question-text">{item.q}</span>
          </button>
          <div data-slot="faq-answer" set:html={item.a} />
        </div>
      ))
    }
  </div>
</section>
