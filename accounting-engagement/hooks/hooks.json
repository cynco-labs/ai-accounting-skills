{
  "description": "Resume banner when an engagement_state.json is found near the working directory",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session-start.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
